# =============================================================
# root/.env.example
# Edu-Platform — Global Environment Variables Template
# Copy this to .env (and Backend/.env, Frontend/.env accordingly)
# =============================================================

# ── BACKEND SETTINGS ──────────────────────────────────────────
# App Settings
APP_NAME=Edu-Platform
APP_VERSION=1.0.0
DEBUG=False
PORT=8000

# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/edu_platform
DATABASE_NAME=edu_platform

# JWT Security
SECRET_KEY=generate-a-long-random-string-here-32-chars-plus
REFRESH_SECRET_KEY=generate-another-long-random-string-here

# CORS Origins (Comma separated for production)
# Example: https://access-2-education.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI & ML ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ML Path (Relative to Backend folder)
ML_MODELS_PATH=../ML/models

# ── EMAIL / OTP ───────────────────────────────────────────────
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ── FRONTEND SETTINGS ─────────────────────────────────────────
# This variable is needed by the Vite build
VITE_API_URL=https://your-api-domain.com
VITE_DEMO_MODE=false
